{
  "name": "letters-and-numbers-api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for the Letters & Numbers educational PWA. Sync, parent auth, cross-device progress.",
  "scripts": {
    "dev": "next dev -p 3013",
    "build": "next build",
    "start": "next start -p 3013",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.js",
    "db:studio": "drizzle-kit studio"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "next": "16.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "drizzle-orm": "0.30.10",
    "postgres": "3.4.4",
    "zod": "3.23.8",
    "pino": "9.1.0"
  },
  "devDependencies": {
    "@types/node": "20.12.7",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "drizzle-kit": "0.21.4",
    "typescript": "5.4.5"
  }
}
