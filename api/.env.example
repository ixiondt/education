# Letters & Numbers backend — environment template
# Copy to .env on the droplet and fill in real values. Never commit .env.

# PostgreSQL connection (shared droplet instance)
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://lnum_user:CHANGE_ME@host.containers.internal:5432/db_lnum

# Optional: bumps Pino's log level (default: info in prod, debug in dev)
LOG_LEVEL=info

# Future (Turn 2):
# RESEND_API_KEY=re_xxx              # Scoped Resend key for magic-link emails
# EMAIL_FROM=Letters <letters@guardcybersolutionsllc.com>
# AUTH_SECRET=                       # 32-byte random for JWT signing
# PUBLIC_ORIGIN=https://letters.guardcybersolutionsllc.com
